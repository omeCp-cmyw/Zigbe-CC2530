        RSEG BANKED_CODE:CODE:NOROOT(0)
//  705 int controlRelay(unsigned char* v_MessageData)//!< 判断协调器的命令
controlRelay:
        CFI Block cfiBlock23 Using cfiCommon0
        CFI Function controlRelay
        CODE
//  706 {
        FUNCALL controlRelay, openLed
        LOCFRAME ISTACK, 2, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 0, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 2, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 0, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
//  707   if(v_MessageData == NULL)  //!<  传进来的数据是否为空
        MOV     A,R2
        ORL     A,R3
        JNZ     ??controlRelay_0
//  708   {
//  709     return 0;
        MOV     R2,#0x0
        SJMP    ??controlRelay_1
//  710   }
//  711   if(ENDNUM == 3)
//  712   {
//  713     if(v_MessageData[0] == '1')
??controlRelay_0:
        MOV     DPL,R2
        MOV     DPH,R3
        MOVX    A,@DPTR
        XRL     A,#0x31
        JNZ     ??controlRelay_2
//  714     {
//  715       return (openLed( v_MessageData));
        ; Setup parameters for call to function openLed
        LCALL   ??openLed?relay
        SJMP    ??controlRelay_3
//  716     }
//  717   }
//  718   return 2;
??controlRelay_2:
        MOV     R2,#0x2
??controlRelay_1:
        MOV     R3,#0x0
??controlRelay_3:
        LJMP    ?Subroutine0 & 0xFFFF
        CFI EndBlock cfiBlock23
//  719 }
//  720 //!< 控制led灯的开关

        RSEG BANKED_CODE:CODE:NOROOT(0)
//  721 unsigned int openLed(unsigned char* v_MessageData)
openLed:
        CFI Block cfiBlock24 Using cfiCommon0
        CFI Function openLed
        CODE
//  722 {
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
//  723     
//  724     if((v_MessageData[1]== 'O' && v_MessageData[2]== 'N')||(v_MessageData[1]== 'o' && v_MessageData[2]== 'n')) //!< on打开
        MOV     DPL,R2
        MOV     DPH,R3
        INC     DPTR
        MOVX    A,@DPTR
        XRL     A,#0x4f
        MOV     DPL,R2
        MOV     DPH,R3
        INC     DPTR
        JNZ     ??openLed_0
        INC     DPTR
        MOVX    A,@DPTR
        XRL     A,#0x4e
        JZ      ??openLed_1
//  725     {
//  726       
//  727       return 1;
//  728     }
//  729     else if((v_MessageData[1]== 'O' && v_MessageData[2]== 'F')||(v_MessageData[1]== 'o' && v_MessageData[2]== 'f'))//!< of关闭
//  730     {
//  731        return 0;
??openLed_2:
        MOV     R2,#0x0
??openLed_3:
        MOV     R3,#0x0
//  732     }
        LJMP    ?Subroutine0 & 0xFFFF
??openLed_0:
        MOVX    A,@DPTR
        XRL     A,#0x6f
