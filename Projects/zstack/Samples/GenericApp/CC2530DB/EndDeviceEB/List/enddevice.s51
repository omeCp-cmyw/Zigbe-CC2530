//  638 void controlBeer(unsigned char* v_MsgData)
controlBeer:
        CFI Block cfiBlock19 Using cfiCommon0
        CFI Function controlBeer
        CODE
//  639 {
        FUNCALL controlBeer, Delay_ms
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 9, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 9, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        FUNCALL controlBeer, Delay_ms
        LOCFRAME ISTACK, 0, STACK
        LOCFRAME PSTACK, 0, STACK
        LOCFRAME XSTACK, 9, STACK
        LOCFRAME IOVERLAY, 0, STATIC
        LOCFRAME DOVERLAY, 0, STATIC
        ARGFRAME ISTACK, 0, STACK
        ARGFRAME PSTACK, 0, STACK
        ARGFRAME XSTACK, 9, STACK
        ARGFRAME IOVERLAY, 0, STATIC
        ARGFRAME DOVERLAY, 0, STATIC
        MOV     A,#-0x9
        LCALL   ?BANKED_ENTER_XDATA
        CFI DPH0 load(1, XDATA, add(CFA_XSP16, literal(-1)))
        CFI DPL0 load(1, XDATA, add(CFA_XSP16, literal(-2)))
        CFI ?BRET_EXT load(1, XDATA, add(CFA_XSP16, literal(-3)))
        CFI ?RET_HIGH load(1, XDATA, add(CFA_XSP16, literal(-4)))
        CFI ?RET_LOW load(1, XDATA, add(CFA_XSP16, literal(-5)))
        CFI R7 load(1, XDATA, add(CFA_XSP16, literal(-6)))
        CFI V0 load(1, XDATA, add(CFA_XSP16, literal(-7)))
        CFI VB load(1, XDATA, add(CFA_XSP16, literal(-8)))
        CFI R6 load(1, XDATA, add(CFA_XSP16, literal(-9)))
        CFI CFA_SP SP+0
        CFI CFA_XSP16 add(XSP16, 9)
        ; Saved register size: 9
        ; Auto size: 0
        MOV     A,R2
        MOV     R6,A
        MOV     A,R3
        MOV     R7,A
//  640   if(v_MsgData == NULL)
        MOV     A,R6
        ORL     A,R7
        JZ      ??controlBeer_0
//  641   {
//  642     return;
//  643   }
//  644   if(v_MsgData[0] == 'y' && v_MsgData[1] == 'e' &&v_MsgData[2] == 's')
        MOV     DPL,R6
        MOV     DPH,R7
        MOVX    A,@DPTR
        XRL     A,#0x79
        JNZ     ??controlBeer_1
        INC     DPTR
        MOVX    A,@DPTR
        XRL     A,#0x65
        JNZ     ??controlBeer_0
        MOV     DPL,R6
        MOV     DPH,R7
        INC     DPTR
        INC     DPTR
        MOVX    A,@DPTR
        XRL     A,#0x73
        JNZ     ??controlBeer_0
//  645   {
//  646     
//  647     TIMER_START();        //!< 检测到异常气体/火焰时蜂鸣器响
        ORL     0xe4,#0x3
//  648     BEEP_PIN = 1;
        SETB    0x80.7
//  649     Delay_ms(500);
        ; Setup parameters for call to function Delay_ms
        MOV     R2,#-0xc
        MOV     R3,#0x1
        LCALL   ??Delay_ms?relay
//  650     TIMER_STOP();         //!< 气体正常/无火焰不响
        ANL     0xe4,#0xfc
//  651     Delay_ms(500);
        ; Setup parameters for call to function Delay_ms
        MOV     R2,#-0xc
        MOV     R3,#0x1
        LCALL   ??Delay_ms?relay
//  652   }
//  653   if(v_MsgData[0] == 'n' && v_MsgData[1] == 'o' &&v_MsgData[2] == 'o')
??controlBeer_1:
        MOV     DPL,R6
        MOV     DPH,R7
        MOVX    A,@DPTR
        XRL     A,#0x6e
        JNZ     ??controlBeer_0
        INC     DPTR
        MOVX    A,@DPTR
        XRL     A,#0x6f
        JNZ     ??controlBeer_0
        MOV     DPL,R6
        MOV     DPH,R7
        INC     DPTR
        INC     DPTR
        MOVX    A,@DPTR
        XRL     A,#0x6f
        JNZ     ??controlBeer_0
//  654   {
//  655     TIMER_STOP();         //!< 气体正常/无火焰不响
        ANL     0xe4,#0xfc
//  656   }
??controlBeer_0:
        LJMP    ?Subroutine2 & 0xFFFF
        CFI EndBlock cfiBlock19
        REQUIRE T1CTL
        REQUIRE _A_P0
//  657 }
