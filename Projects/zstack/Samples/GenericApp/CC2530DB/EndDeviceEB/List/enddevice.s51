// 1054 /*********************************************************************
// 1055  * @fn      GenericApp_ProcessRtosMessage
// 1056  *
// 1057  * @brief   Receive message from RTOS queue, send response back.
// 1058  *
// 1059  * @param   none
// 1060  *
// 1061  * @return  none
// 1062  */
// 1063 static void GenericApp_ProcessRtosMessage( void )
// 1064 {
// 1065   osalQueue_t inMsg;
// 1066 
// 1067   if ( osal_queue_receive( OsalQueue, &inMsg, 0 ) == pdPASS )
// 1068   {
// 1069     uint8 cmndId = inMsg.cmnd;
// 1070     uint32 counter = osal_build_uint32( inMsg.cbuf, 4 );
// 1071 
// 1072     switch ( cmndId )
// 1073     {
// 1074       case CMD_INCR:
// 1075         counter += 1;  /* Increment the incoming counter */
// 1076                        /* Intentionally fall through next case */
// 1077 
// 1078       case CMD_ECHO:
// 1079       {
// 1080         userQueue_t outMsg;
// 1081 
// 1082         outMsg.resp = RSP_CODE | cmndId;  /* Response ID */
// 1083         osal_buffer_uint32( outMsg.rbuf, counter );    /* Increment counter */
// 1084         osal_queue_send( UserQueue1, &outMsg, 0 );  /* Send back to UserTask */
// 1085         break;
// 1086       }
// 1087       
// 1088       default:
// 1089         break;  /* Ignore unknown command */    
// 1090     }
// 1091   }
// 1092 }
// 1093 #endif
