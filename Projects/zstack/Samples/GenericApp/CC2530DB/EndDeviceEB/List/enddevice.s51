        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
// 1047     Init_Beep();
        ; Setup parameters for call to function Init_Beep
        LCALL   ??Init_Beep?relay
// 1048     InitTimer();
        ; Setup parameters for call to function InitTimer
        LCALL   ??InitTimer?relay
// 1049 }
        SJMP    ?Subroutine0
