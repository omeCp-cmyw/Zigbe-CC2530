//  447 
//  448 /*********************************************************************
//  449  * @fn      GenericApp_ProcessZDOMsgs()
//  450  *
//  451  * @brief   Process response messages
//  452  *
//  453  * @param   none
//  454  *
//  455  * @return  none
//  456  */
//  457 static void GenericApp_ProcessZDOMsgs( zdoIncomingMsg_t *inMsg )
//  458 {
//  459   switch ( inMsg->clusterID )
//  460   {
//  461     case End_Device_Bind_rsp://请求是发给我们的 Coordinator
//  462       if ( ZDO_ParseBindRsp( inMsg ) == ZSuccess )//請求绑定
//  463       {
//  464         // Light LED
//  465         HalLedSet( HAL_LED_4, HAL_LED_MODE_ON );//绑定成功
//  466       }
//  467 #if defined( BLINK_LEDS )
//  468       else
//  469       {
//  470         // Flash LED to show failure
//  471         HalLedSet ( HAL_LED_4, HAL_LED_MODE_FLASH );//绑定失败
//  472       }
//  473 #endif
//  474       break;
//  475 
//  476     case Match_Desc_rsp:
//  477       {
//  478         ZDO_ActiveEndpointRsp_t *pRsp = ZDO_ParseEPListRsp( inMsg );
//  479         if ( pRsp )
//  480         {
//  481           if ( pRsp->status == ZSuccess && pRsp->cnt )
//  482           {
//  483             GenericApp_DstAddr.addrMode = (afAddrMode_t)Addr16Bit;
//  484             GenericApp_DstAddr.addr.shortAddr = pRsp->nwkAddr;
//  485             // Take the first endpoint, Can be changed to search through endpoints
//  486             GenericApp_DstAddr.endPoint = pRsp->epList[0];
//  487 
//  488             // Light LED
//  489             HalLedSet( HAL_LED_4, HAL_LED_MODE_ON );
//  490             
//  491           }
//  492           osal_mem_free( pRsp );
//  493         }
//  494       }
//  495       break;
//  496   }
//  497 }
//  498 
//  499 /*********************************************************************
//  500  * @fn      GenericApp_HandleKeys
//  501  *
//  502  * @brief   Handles all key events for this device.
//  503  *
//  504  * @param   shift - true if in shift/alt.
//  505  * @param   keys - bit field for key events. Valid entries:
//  506  *                 HAL_KEY_SW_4
//  507  *                 HAL_KEY_SW_3
//  508  *                 HAL_KEY_SW_2
//  509  *                 HAL_KEY_SW_1
//  510  *
//  511  * @return  none
//  512  */
//  513 static void GenericApp_HandleKeys( uint8 shift, uint8 keys )
//  514 {
//  515   zAddrType_t dstAddr;
//  516 
//  517   // Shift is used to make each button/switch dual purpose.
//  518   if ( shift )
//  519   {
//  520     if ( keys & HAL_KEY_SW_1 )
//  521     {
//  522     }
//  523     if ( keys & HAL_KEY_SW_2 )
//  524     {
//  525     }
//  526     if ( keys & HAL_KEY_SW_3 )
//  527     {
//  528     }
//  529     if ( keys & HAL_KEY_SW_4 )
//  530     {
//  531     }
//  532   }
//  533   else
//  534   {
//  535     if ( keys & HAL_KEY_SW_1 )
//  536     {
//  537       // Since SW1 isn't used for anything else in this application...
//  538 #if defined( SWITCH1_BIND )
//  539       // we can use SW1 to simulate SW2 for devices that only have one switch,
//  540       keys |= HAL_KEY_SW_2;
//  541 #elif defined( SWITCH1_MATCH )
//  542       // or use SW1 to simulate SW4 for devices that only have one switch
//  543       keys |= HAL_KEY_SW_4;
//  544 #endif
//  545     }
//  546 
//  547     if ( keys & HAL_KEY_SW_2 )
//  548     {
//  549       HalLedSet ( HAL_LED_4, HAL_LED_MODE_OFF );
//  550 
//  551       // Initiate an End Device Bind Request for the mandatory endpoint
//  552       dstAddr.addrMode = Addr16Bit;
//  553       dstAddr.addr.shortAddr = 0x0000; // Coordinator
//  554       ZDP_EndDeviceBindReq( &dstAddr, NLME_GetShortAddr(),
//  555                             GenericApp_epDesc.endPoint,
//  556                             GENERICAPP_PROFID,
//  557                             GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
//  558                             GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
//  559                             FALSE );
//  560     }
//  561 
//  562     if ( keys & HAL_KEY_SW_3 )
//  563     {
//  564     }
//  565 
//  566     if ( keys & HAL_KEY_SW_4 )
//  567     {
//  568       HalLedSet ( HAL_LED_4, HAL_LED_MODE_OFF );
//  569       // Initiate a Match Description Request (Service Discovery)
//  570       dstAddr.addrMode = AddrBroadcast;
//  571       dstAddr.addr.shortAddr = NWK_BROADCAST_SHORTADDR;
//  572       ZDP_MatchDescReq( &dstAddr, NWK_BROADCAST_SHORTADDR,
//  573                         GENERICAPP_PROFID,
//  574                         GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
//  575                         GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
//  576                         FALSE );
//  577     }
//  578   }
//  579 }
