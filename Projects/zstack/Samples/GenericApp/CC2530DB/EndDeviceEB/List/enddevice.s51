//  117 
//  118 
//  119 
//  120 /*********************************************************************
//  121  * CONSTANTS
//  122  */
//  123 
//  124 /*********************************************************************
//  125  * TYPEDEFS
//  126  */
//  127 
//  128 /*********************************************************************
//  129  * GLOBAL VARIABLES
//  130  */
//  131 // This list should be filled with Application specific Cluster IDs.

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
//  132 const cId_t GenericApp_ClusterList[GENERICAPP_MAX_CLUSTERS] =
GenericApp_ClusterList:
        DATA16
        DW 1
        DW 0
        DW 0
        DW 0
//  133 {
//  134   GENERICAPP_CLUSTERID
//  135 };
//  136 

        RSEG XDATA_ROM_C:CONST:REORDER:NOROOT(0)
        DATA8
//  137 const SimpleDescriptionFormat_t GenericApp_SimpleDesc =
GenericApp_SimpleDesc:
        DB 10
        DATA16
        DW 3844
        DW 1
        DATA8
        DB 0
        DB 4
        DATA16
        DW GenericApp_ClusterList
        DATA8
        DB 4
        DATA16
        DW GenericApp_ClusterList
//  138 {
//  139   GENERICAPP_ENDPOINT,              //  int Endpoint;
//  140   GENERICAPP_PROFID,                //  uint16 AppProfId[2];
//  141   GENERICAPP_DEVICEID,              //  uint16 AppDeviceId[2];
//  142   GENERICAPP_DEVICE_VERSION,        //  int   AppDevVer:4;
//  143   GENERICAPP_FLAGS,                 //  int   AppFlags:4;
//  144   GENERICAPP_MAX_CLUSTERS,          //  byte  AppNumInClusters;
//  145   (cId_t *)GenericApp_ClusterList,  //  byte *pAppInClusterList;
//  146   GENERICAPP_MAX_CLUSTERS,          //  byte  AppNumInClusters;
//  147   (cId_t *)GenericApp_ClusterList   //  byte *pAppInClusterList;
//  148 };
//  149 
//  150 // This is the Endpoint/Interface description.  It is defined here, but
//  151 // filled-in in GenericApp_Init().  Another way to go would be to fill
//  152 // in the structure here and make it a "const" (in code space).  The
//  153 // way it's defined in this sample app it is define in RAM.

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//  154 endPointDesc_t GenericApp_epDesc;
GenericApp_epDesc:
        DS 6
        REQUIRE __INIT_XDATA_Z
//  155 
//  156 #define RELAY P1_5       //!< 定义P0.6定义为输出口(继电器控制开关)
//  157 
//  158 /*********************************************************************
//  159  * EXTERNAL VARIABLES
//  160  */
//  161 
//  162 
//  163 /*********************************************************************
//  164  * EXTERNAL FUNCTIONS
//  165  */
//  166 #define FRAME P1_6
//  167 /*********************************************************************
//  168  * LOCAL VARIABLES
//  169  */

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//  170 byte GenericApp_TaskID;   // Task ID for internal task/event processing
GenericApp_TaskID:
        DS 1
        REQUIRE __INIT_XDATA_Z
//  171                           // This variable will be received when
//  172                           // GenericApp_Init() is called.

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//  173 devStates_t GenericApp_NwkState;
GenericApp_NwkState:
        DS 1
        REQUIRE __INIT_XDATA_Z
//  174 
//  175 

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//  176 byte GenericApp_TransID;  // This is the unique message ID (counter)
GenericApp_TransID:
        DS 1
        REQUIRE __INIT_XDATA_Z
//  177 

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//  178 afAddrType_t GenericApp_DstAddr;
GenericApp_DstAddr:
        DS 12
        REQUIRE __INIT_XDATA_Z
//  179 
//  180 #define DATA_PIN P0_6            //定义P0.6口为传感器的输入端
//  181 
//  182 //byte sensorID = '1';
//  183 
//  184 //!< 定义步进电机连接端口
//  185 #define A P0_4 //!< 连接 1N1
//  186 #define B P0_5 //!< 连接 1N2
//  187 #define C P0_6 //!< 连接 1N3
//  188 #define D P0_7 //!< 连接 1N4

        RSEG XDATA_I:XDATA:NOROOT(0)
//  189 uchar funcForward[4] = {0x80,0x40,0x20,0x10};//!< 正转 电机导通相序 D-C-B-A
funcForward:
        DATA32
        DS 4
        REQUIRE `?<Initializer for funcForward>`
        REQUIRE __INIT_XDATA_I

        RSEG XDATA_I:XDATA:NOROOT(0)
//  190 uchar funcReverse[4] = {0x10,0x20,0x40,0x80};//!< 反转 电机导通相序 A-B-C-D
funcReverse:
        DATA32
        DS 4
        REQUIRE `?<Initializer for funcReverse>`
        REQUIRE __INIT_XDATA_I
//  191 

        RSEG XDATA_Z:XDATA:NOROOT(0)
        DATA8
//  192 uchar ucSpeed;
ucSpeed:
        DS 1
        REQUIRE __INIT_XDATA_Z
