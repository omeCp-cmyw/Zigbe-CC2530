// 1014 void InitIO(void)//!< IO引脚初始化工作
InitIO:
        CFI Block cfiBlock49 Using cfiCommon0
        CFI Function InitIO
        CODE
// 1015 {
        ; Saved register size: 0
        ; Auto size: 0
// 1016 	//!< P04 05 06 07定义为普通IO
// 1017 	P0SEL &= 0x0F;  
        ANL     0xf3,#0xf
// 1018 	//!< P04 05 06 07定义为输出
// 1019 	P0DIR |= 0xF0;  
        ORL     0xfd,#0xf0
// 1020 }
        LJMP    ?BRET
        CFI EndBlock cfiBlock49
        REQUIRE P0SEL
        REQUIRE P0DIR
// 1021 

        RSEG BANKED_CODE:CODE:NOROOT(0)
// 1022 void Init_Beep(void)
Init_Beep:
        CFI Block cfiBlock50 Using cfiCommon0
        CFI Function Init_Beep
        CODE
// 1023 {
        ; Saved register size: 0
        ; Auto size: 0
// 1024     P0SEL |= 0x80;          //!< 设置P0.7口为外设
        ORL     0xf3,#0x80
// 1025     P0DIR &= 0x80;          //!< 设置P0.7为输出IO口
        ANL     0xfd,#0x80
// 1026     PERCFG |= 0x40;         //!< 设置定时器1 的I / O 位置   1： 备用位置2
        ORL     0xf1,#0x40
// 1027 }
        LJMP    ?BRET
        CFI EndBlock cfiBlock50
        REQUIRE P0SEL
        REQUIRE P0DIR
        REQUIRE PERCFG
// 1028 
// 1029 //!< 将基准值放入T1CC0 寄存器, 将被比较值放入T1CC3寄存器
// 1030 //!< 当T1CC3中的值与T1CC0中的值相等时，则T1CC3 设置or清除

        RSEG BANKED_CODE:CODE:NOROOT(0)
// 1031 void InitTimer(void)
InitTimer:
        CFI Block cfiBlock51 Using cfiCommon0
        CFI Function InitTimer
        CODE
// 1032 {
        PUSH    DPL
        CFI DPL0 Frame(CFA_SP, 4)
        CFI CFA_SP SP+-4
        PUSH    DPH
        CFI DPH0 Frame(CFA_SP, 5)
        CFI CFA_SP SP+-5
        ; Saved register size: 2
        ; Auto size: 0
// 1033     T1CC0L = 0xff;         //!< PWM duty cycle  周期
        MOV     0xda,#-0x1
// 1034     T1CC0H = 0x0;
        MOV     0xdb,#0x0
// 1035 
// 1036     T1CC3L = 0x30;        //!< PWM signal period 占空比
        MOV     DPTR,#0x62ac
        MOV     A,#0x30
        MOVX    @DPTR,A
// 1037     T1CC3H = 0x00;
        INC     DPTR
        CLR     A
        MOVX    @DPTR,A
// 1038 
// 1039     //!< 等于T1CC0中的数值时候，输出高电平 1； 等于T1CC3中的数值时候，输出低电平 0
// 1040     //!< 其实整个占空比就为50%  为了蜂鸣器输出连续的响声修改了占空比
// 1041     T1CCTL3 = 0x34;
        MOV     DPTR,#0x62a3
        MOV     A,#0x34
        MOVX    @DPTR,A
// 1042     T1CTL |= 0x0f;         //!< divide with 128 and to do i up-down mode
        ORL     0xe4,#0xf
// 1043 }
        SJMP    ?Subroutine0
        CFI EndBlock cfiBlock51
        REQUIRE T1CC0L
        REQUIRE T1CC0H
        REQUIRE T1CTL
// 1044 

        RSEG BANKED_CODE:CODE:NOROOT(0)
