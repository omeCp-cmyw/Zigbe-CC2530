//  570 
//  571     P1SEL &= 0x73; //ČĂ P1.2 P1.3 P1.7ÎŞĆŐÍ¨IOżÚ
        ANL     0xf4,#0x73
//  572     P1DIR |= 0x8C; //°Ń P1.2 P1.3 1.7ÉčÖĂÎŞĘäłö
        ORL     0xfe,#0x8c
//  573     
//  574     LCD_SCL=1;
        SETB    0x90.2
//  575     LCD_RST=0;
        CLR     0x90.7
//  576     LCD_DLY_ms(50);
