        LCALL   ??LCD_WrCmd?relay
//  597     LCD_WrCmd(0xdb);//--set vcomh
        ; Setup parameters for call to function LCD_WrCmd
        MOV     R1,#-0x25
        LCALL   ??LCD_WrCmd?relay
//  598     LCD_WrCmd(0x40);//Set VCOM Deselect Level
