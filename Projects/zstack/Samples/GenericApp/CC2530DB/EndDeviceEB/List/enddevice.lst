   \                                 In  segment BANKED_CODE, align 1, keep-with-next
    231          void UartInitPort0(void )
   \                     UartInitPort0:
    232          {
   \   000000   C082         PUSH    DPL
   \   000002   C083         PUSH    DPH
   \   000004                ; Saved register size: 2
   \   000004                ; Auto size: 29
   \   000004   74E3         MOV     A,#-0x1d
   \   000006   12....       LCALL   ?ALLOC_XSTACK8
    233          
    234                    halUARTCfg_t uartConfig;//顶一个串口结构体
    235                    uartConfig.configured             =TRUE;//串口配置为真
   \   000009   85..82       MOV     DPL,?XSP + 0
   \   00000C   85..83       MOV     DPH,?XSP + 1
   \   00000F   7401         MOV     A,#0x1
   \   000011   F0           MOVX    @DPTR,A
    236                    uartConfig.baudRate               =HAL_UART_BR_115200;//波特率为115200
   \   000012   12....       LCALL   ?XSTACK_DISP0_8
   \   000015   7404         MOV     A,#0x4
   \   000017   F0           MOVX    @DPTR,A
    237                    uartConfig.flowControl            =FALSE;//流控制为假
   \   000018   7402         MOV     A,#0x2
   \   00001A   12....       LCALL   ?XSTACK_DISP0_8
   \   00001D   E4           CLR     A
   \   00001E   F0           MOVX    @DPTR,A
    238                    uartConfig.callBackFunc       =    rxCB;
   \   00001F   741B         MOV     A,#0x1b
   \   000021   12....       LCALL   ?XSTACK_DISP0_8
   \   000024   74..         MOV     A,#??rxCB?relay & 0xff
   \   000026   F0           MOVX    @DPTR,A
   \   000027   A3           INC     DPTR
   \   000028   74..         MOV     A,#(??rxCB?relay >> 8) & 0xff
   \   00002A   12....       LCALL   ?Subroutine5 & 0xFFFF
    239                    HalUARTOpen(HAL_UART_PORT_0,&uartConfig);// 打开串口0
   \                     ??CrossCallReturnLabel_2:
   \   00002D   AA82         MOV     R2,DPL
   \   00002F   AB83         MOV     R3,DPH
   \   000031   7900         MOV     R1,#0x0
   \   000033   12....       LCALL   ??HalUARTOpen?relay
    240          }
   \   000036   741D         MOV     A,#0x1d
   \   000038   12....       LCALL   ?DEALLOC_XSTACK8
   \   00003B   02....       LJMP    ?Subroutine0 & 0xFFFF

   \                                 In  segment BANKED_CODE, align 1, keep-with-next
   \                     ?Subroutine5:
   \   000000   F0           MOVX    @DPTR,A
   \   000001                ; Setup parameters for call to function HalUARTOpen
