    582           * LOCAL FUNCTIONS
    583           */
    584          
    585          /*********************************************************************
    586           * @fn      GenericApp_MessageMSGCB
    587           *
    588           * @brief   Data message processor callback.  This function processes
    589           *          any incoming data - probably from other devices.  So, based
    590           *          on cluster ID, perform the intended action.
    591           *
    592           * @param   none
    593           *
    594           * @return  none
    595           */
    596          

   \                                 In  segment XDATA_Z, align 1, keep-with-next
    597          int iRelayState = 0;
   \                     iRelayState:
   \   000000                DS 2
   \   000002                REQUIRE __INIT_XDATA_Z
    598          
    599          static void GenericApp_MessageMSGCB( afIncomingMSGPacket_t *pkt )
    600          {
    601           // unsigned char cGetDate[10];//获取协调器发来的命令
    602            switch ( pkt->clusterId )
    603            {
    604              case GENERICAPP_CLUSTERID:
    605                HalUARTWrite(0, pkt->cmd.Data, pkt->cmd.DataLength);  //!< 输出接收到的数据,通过串口发送
    606                //osal_memcpy(cGetDate,pkt->cmd.Data, pkt->cmd.DataLength);
    607                if(ENDNUM == 3)
    608                {
    609                  Delay_ms(5);
    610                  switch(controlRelay(pkt->cmd.Data))//!< 判断协调器是否对终端的继电器进行操作
    611                {
    612                  case 0:
    613                    RELAY  = 1;  //!< 继电器关闭状态
    614                    iRelayState = 1;
    615                    break;
    616                  case 1:
    617                    RELAY  = 0;  //!< 继电器打开状态
    618                    iRelayState = 0;
    619                    break;
    620                  default:
    621                    break;
    622                }
    623                break;
    624                }
    625                
    626            }
    627            if(ENDNUM == 4)
    628            {
    629              controlBeer(pkt->cmd.Data);
    630            }
    631            if(ENDNUM == 5)
    632            {
