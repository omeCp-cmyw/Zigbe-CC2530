    486          /*********************************************************************
    487           * @fn      GenericApp_MessageMSGCB
    488           *
    489           * @brief   Data message processor callback.  This function processes
    490           *          any incoming data - probably from other devices.  So, based
    491           *          on cluster ID, perform the intended action.
    492           *
    493           * @param   none
    494           *
    495           * @return  none
    496           */
    497          static void GenericApp_MessageMSGCB( afIncomingMSGPacket_t *pkt )
    498          {
    499            switch ( pkt->clusterId )
    500            {
    501              case GENERICAPP_CLUSTERID:
    502                // "the" message
    503          #if defined( LCD_SUPPORTED )
    504                HalLcdWriteScreen( (char*)pkt->cmd.Data, "rcvd" );
    505          #elif defined( WIN32 )
    506                WPRINTSTR( pkt->cmd.Data );
    507          #endif
    508                break;
    509            }
    510          }
