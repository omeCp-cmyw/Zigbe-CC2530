    548          /*********************************************************************
    549           * @fn      GenericApp_ProcessRtosMessage
    550           *
    551           * @brief   Receive message from RTOS queue, send response back.
    552           *
    553           * @param   none
    554           *
    555           * @return  none
    556           */
    557          static void GenericApp_ProcessRtosMessage( void )
    558          {
    559            osalQueue_t inMsg;
    560          
    561            if ( osal_queue_receive( OsalQueue, &inMsg, 0 ) == pdPASS )
    562            {
    563              uint8 cmndId = inMsg.cmnd;
    564              uint32 counter = osal_build_uint32( inMsg.cbuf, 4 );
    565          
    566              switch ( cmndId )
    567              {
    568                case CMD_INCR:
    569                  counter += 1;  /* Increment the incoming counter */
    570                                 /* Intentionally fall through next case */
    571          
    572                case CMD_ECHO:
    573                {
    574                  userQueue_t outMsg;
    575          
    576                  outMsg.resp = RSP_CODE | cmndId;  /* Response ID */
    577                  osal_buffer_uint32( outMsg.rbuf, counter );    /* Increment counter */
    578                  osal_queue_send( UserQueue1, &outMsg, 0 );  /* Send back to UserTask */
    579                  break;
    580                }
    581                
    582                default:
    583                  break;  /* Ignore unknown command */    
    584              }
    585            }
    586          }
    587          #endif
