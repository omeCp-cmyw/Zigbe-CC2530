    643          /*********************************************************************
    644           * @fn      GenericApp_SendTheMessage
    645           *
    646           * @brief   Send "the" message.
    647           *
    648           * @param   none
    649           *
    650           * @return  none
    651           */
    652          static void GenericApp_SendTheMessage( void )//!< ·˘ĂüÁî¸řÖŐ¶ËĂÇŁ¬¶ÔĆä˝řĐĐżŘÖĆ
    653          {
    654            if(strlen((char *)uchBuf) != 0)//!< ĹĐ¶ĎĘÇ·ńÓĐ·˘ËÍĂüÁî
    655            {
    656              if(AF_DataRequest( &GenericApp_DstAddr, &GenericApp_epDesc,
    657                                       GENERICAPP_CLUSTERID,
    658                                        10,
    659                                       (unsigned char *)uchBuf,
    660                                       &GenericApp_TransID,
    661                                       AF_DISCV_ROUTE, AF_DEFAULT_RADIUS)== afStatus_SUCCESS )
    662              {
    663                osal_memset(uchBuf,0,strlen((char *)uchBuf));//!< ·˘ÍęĂüÁî˝«Ęý×éÇĺżŐŁ¬ŇÔ±ăĎÂŇ»´ÎĘąÓĂ
    664              }
    665            }
    666          }
    667          
    668          #if defined( IAR_ARMCM3_LM )
    669          /*********************************************************************
    670           * @fn      GenericApp_ProcessRtosMessage
    671           *
    672           * @brief   Receive message from RTOS queue, send response back.
    673           *
    674           * @param   none
    675           *
    676           * @return  none
    677           */
    678          static void GenericApp_ProcessRtosMessage( void )
    679          {
    680            osalQueue_t inMsg;
    681          
    682            if ( osal_queue_receive( OsalQueue, &inMsg, 0 ) == pdPASS )
    683            {
    684              uint8 cmndId = inMsg.cmnd;
    685              uint32 counter = osal_build_uint32( inMsg.cbuf, 4 );
    686          
    687              switch ( cmndId )
    688              {
    689                case CMD_INCR:
    690                  counter += 1;  /* Increment the incoming counter */
    691                                 /* Intentionally fall through next case */
    692          
    693                case CMD_ECHO:
    694                {
    695                  userQueue_t outMsg;
    696          
    697                  outMsg.resp = RSP_CODE | cmndId;  /* Response ID */
    698                  osal_buffer_uint32( outMsg.rbuf, counter );    /* Increment counter */
    699                  osal_queue_send( UserQueue1, &outMsg, 0 );  /* Send back to UserTask */
    700                  break;
    701                }
    702                
    703                default:
    704                  break;  /* Ignore unknown command */    
    705              }
    706            }
    707          }
    708          #endif
