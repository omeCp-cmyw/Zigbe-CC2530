    406          /*********************************************************************
    407           * @fn      GenericApp_ProcessZDOMsgs()
    408           *
    409           * @brief   Process response messages
    410           *
    411           * @param   none
    412           *
    413           * @return  none
    414           */
    415          static void GenericApp_ProcessZDOMsgs( zdoIncomingMsg_t *inMsg )
    416          {
    417            switch ( inMsg->clusterID )
    418            {
    419              case End_Device_Bind_rsp:
    420                if ( ZDO_ParseBindRsp( inMsg ) == ZSuccess )
    421                {
    422                  // Light LED
    423                  HalLedSet( HAL_LED_4, HAL_LED_MODE_ON );
    424                }
    425          #if defined( BLINK_LEDS )
    426                else
    427                {
    428                  // Flash LED to show failure
    429                  HalLedSet ( HAL_LED_4, HAL_LED_MODE_FLASH );
    430                }
    431          #endif
    432                break;
    433          
    434              case Match_Desc_rsp:
    435                {
    436                  ZDO_ActiveEndpointRsp_t *pRsp = ZDO_ParseEPListRsp( inMsg );
    437                  if ( pRsp )
    438                  {
    439                    if ( pRsp->status == ZSuccess && pRsp->cnt )
    440                    {
    441                      GenericApp_DstAddr.addrMode = (afAddrMode_t)Addr16Bit;
    442                      GenericApp_DstAddr.addr.shortAddr = pRsp->nwkAddr;
    443                      // Take the first endpoint, Can be changed to search through endpoints
    444                      GenericApp_DstAddr.endPoint = pRsp->epList[0];
    445          
    446                      // Light LED
    447                      HalLedSet( HAL_LED_4, HAL_LED_MODE_ON );
    448                    }
    449                    osal_mem_free( pRsp );
    450                  }
    451                }
    452                break;
    453            }
    454          }
    455          
    456          /*********************************************************************
    457           * @fn      GenericApp_HandleKeys
    458           *
    459           * @brief   Handles all key events for this device.
    460           *
    461           * @param   shift - true if in shift/alt.
    462           * @param   keys - bit field for key events. Valid entries:
    463           *                 HAL_KEY_SW_4
    464           *                 HAL_KEY_SW_3
    465           *                 HAL_KEY_SW_2
    466           *                 HAL_KEY_SW_1
    467           *
    468           * @return  none
    469           */
    470          static void GenericApp_HandleKeys( uint8 shift, uint8 keys )
    471          {
    472            zAddrType_t dstAddr;
    473          
    474            // Shift is used to make each button/switch dual purpose.
    475            if ( shift )
    476            {
    477              if ( keys & HAL_KEY_SW_1 )
    478              {
    479              }
    480              if ( keys & HAL_KEY_SW_2 )
    481              {
    482              }
    483              if ( keys & HAL_KEY_SW_3 )
    484              {
    485              }
    486              if ( keys & HAL_KEY_SW_4 )
    487              {
    488              }
    489            }
    490            else
    491            {
    492              if ( keys & HAL_KEY_SW_1 )
    493              {
    494                // Since SW1 isn't used for anything else in this application...
    495          #if defined( SWITCH1_BIND )
    496                // we can use SW1 to simulate SW2 for devices that only have one switch,
    497                keys |= HAL_KEY_SW_2;
    498          #elif defined( SWITCH1_MATCH )
    499                // or use SW1 to simulate SW4 for devices that only have one switch
    500                keys |= HAL_KEY_SW_4;
    501          #endif
    502              }
    503          
    504              if ( keys & HAL_KEY_SW_2 )
    505              {
    506                HalLedSet ( HAL_LED_4, HAL_LED_MODE_OFF );
    507          
    508                // Initiate an End Device Bind Request for the mandatory endpoint
    509                dstAddr.addrMode = Addr16Bit;
    510                dstAddr.addr.shortAddr = 0x0000; // Coordinator
    511                ZDP_EndDeviceBindReq( &dstAddr, NLME_GetShortAddr(),//»ńČˇ¶ĚµŘÖ·
    512                                      GenericApp_epDesc.endPoint,
    513                                      GENERICAPP_PROFID,
    514                                      GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
    515                                      GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
    516                                      FALSE );
    517              }
    518          
    519              if ( keys & HAL_KEY_SW_3 )
    520              {
    521              }
    522          
    523              if ( keys & HAL_KEY_SW_4 )
    524              {
    525                HalLedSet ( HAL_LED_4, HAL_LED_MODE_OFF );
    526                // Initiate a Match Description Request (Service Discovery)
    527                dstAddr.addrMode = AddrBroadcast;
    528                dstAddr.addr.shortAddr = NWK_BROADCAST_SHORTADDR;
    529                ZDP_MatchDescReq( &dstAddr, NWK_BROADCAST_SHORTADDR,
    530                                  GENERICAPP_PROFID,
    531                                  GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
    532                                  GENERICAPP_MAX_CLUSTERS, (cId_t *)GenericApp_ClusterList,
    533                                  FALSE );
    534              }
    535            }
    536          }
